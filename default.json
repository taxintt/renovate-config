{
    "extends": [
        "config:base",
        ":separateMultipleMajorReleases",
        "local>taxintt/renovate-config:schedule",
        "local>taxintt/renovate-config:docker"
    ],
    "labels": [
        "renovate"
    ],
    "packageRules": [
        {
            "packagePatterns": [
                "^(?!.*@types).*$"
            ],
            "groupName": "default"
        },
        {
            "packagePatterns": [
                "^@types/.*$"
            ],
            "groupName": "devDependencies"
        }
    ]
}